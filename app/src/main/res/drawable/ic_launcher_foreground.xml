<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 1. Glowing Hexagonal Frame with Neon Green to Electric Blue Gradient -->
    <path
        android:pathData="M54,18 L84,35.3 L84,70.7 L54,88 L24,70.7 L24,35.3 Z"
        android:strokeWidth="3"
        android:strokeLineJoin="round"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="24"
                android:startY="18"
                android:endX="84"
                android:endY="88"
                android:type="linear">
                <item android:offset="0.0" android:color="#A3E635" /> <!-- Lime Neon -->
                <item android:offset="0.5" android:color="#10B981" /> <!-- Emeraly/Green -->
                <item android:offset="1.0" android:color="#06B6D4" /> <!-- Cyan Blue -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- 2. Sweeping Energy Tracking Loop Arrow -->
    <path
        android:pathData="M 33,68 A 22,22 0 1,1 75,40"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeColor="#1F4E79" />
        
    <!-- 3. Pulse (EKG/Heartbeat) Wave Line crossing horizontally -->
    <path
        android:pathData="M24,54 L38,54 L41,38 L45,70 L49,54 L55,54 L58,40 L61,66 L64,54 L84,54"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="24"
                android:startY="54"
                android:endX="84"
                android:endY="54"
                android:type="linear">
                <item android:offset="0.0" android:color="#059669" /> <!-- Emerald Darker -->
                <item android:offset="0.5" android:color="#34D399" /> <!-- Minty Green -->
                <item android:offset="1.0" android:color="#0891B2" /> <!-- Cyan Darker -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- 4. Dynamic Runner Holding Dumbbell -->
    <!-- Runner's Head -->
    <path
        android:fillColor="#F8FAFC"
        android:pathData="M54,34 a3.5,3.5 0,1,0 0,-7 a3.5,3.5 0,1,0 0,7 z" />

    <!-- Runner's Body & Limbs -->
    <path
        android:fillColor="#F1F5F9"
        android:pathData="M63.5,41.9 l-4.1,-5.9 c-0.8,-1.1 -2.1,-1.8 -3.5,-1.8 h-4.3 c-1.3,0 -2.6,0.6 -3.4,1.6 L44,41.1 c-0.5,0.6 -0.4,1.5 0.2,2 s1.5,0.4 2,-0.2 l4.3,-5.2 v8.5 c0,1 -0.5,2 -1.3,2.6 l-6.8,5 c-0.6,0.5 -0.7,1.4 -0.2,2 s1.4,0.7 2,0.2 l7.1,-5.2 c1.4,-1 2.2,-2.6 2.2,-4.3 v-6 h1.5 l3.8,7.6 c0.5,1 1.5,1.6 2.6,1.6 h5.8 c0.8,0 1.5,-0.7 1.5,-1.5 s-0.7,-1.5 -1.5,-1.5 h-4.6 l-3.2,-6.4 l2.1,-2.4 l4.2,4.8 c0.3,0.3 0.7,0.5 1.1,0.5 h3 c0.8,0 1.5,-0.7 1.5,-1.5 C65.5,42.7 64.7,42.1 63.5,41.9 z" />

    <!-- 5. Dumbbell (held in hand at around 64, 43) -->
    <!-- Dumbbell Bar -->
    <path
        android:pathData="M64,41 L68,37"
        android:strokeColor="#F8FAFC"
        android:strokeWidth="1.5"
        android:strokeLineCap="round" />
    <!-- Dumbbell Weight Plate Left -->
    <path
        android:pathData="M62,42 L65,39"
        android:strokeColor="#A3E635"
        android:strokeWidth="3.5"
        android:strokeLineCap="round" />
    <!-- Dumbbell Weight Plate Right -->
    <path
        android:pathData="M67,37 L70,34"
        android:strokeColor="#A3E635"
        android:strokeWidth="3.5"
        android:strokeLineCap="round" />

</vector>
